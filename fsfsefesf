SpawnSection:Button({
    Title = "Spawn Item",
    Description = "Click to spawn the selected item",
    Callback = function()
        if selectedItem == "" then
            Window:Notify({
                Title = "Error",
                Description = "Please enter an item name",
                Duration = 3
            })
            return
        end
        
        local originalName = getOriginalName(selectedItem)
        spawnItem(originalName)
        
        if autoLoadEnabled then
            if not table.find(savedItems, selectedItem) then
                table.insert(savedItems, selectedItem)
                saveItems()
            end
        end
        
        Window:Notify({
            Title = "Success",
            Description = "Spawned: " .. selectedItem,
            Duration = 3
        })
        selectedItem = ""
        inputBox:Set("")
    end
})

