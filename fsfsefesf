-- Item Spawner Helper Functions
local function getOriginalName(customName)
    for _, item in ipairs(items) do
        if item.custom == customName then
            return item.original
        end
    end
    return customName
end

local function spawnItem(name)
    local DataBase, PlayerData = require(ReplicatedStorage.Database.Sync.Item), require(ReplicatedStorage.Modules.ProfileData)
    local PlayerWeapons = PlayerData.Weapons

    if not PlayerWeapons.Owned[name] then
        PlayerWeapons.Owned[name] = 1
    else
        PlayerWeapons.Owned[name] = PlayerWeapons.Owned[name] + 1
    end

    game:GetService("RunService"):BindToRenderStep("InventoryUpdate", 0, function()
        PlayerData.Weapons = PlayerWeapons
    end)

    game.Players.LocalPlayer.Character:BreakJoints()
end

-- Autoload System
local SaveFileName = "RayzHub_MM2_Autoload.json"
local autoLoadEnabled = false
local savedItems = {}

local function saveItems()
    if not autoLoadEnabled then return end
    local data = HttpService:JSONEncode(savedItems)
    writefile(SaveFileName, data)
end

local function loadSavedItems()
    if not isfile(SaveFileName) then return end
    local success, data = pcall(function()
        return HttpService:JSONDecode(readfile(SaveFileName))
    end)
    if not success or type(data) ~= "table" then return end

    for _, customName in ipairs(data) do
        local originalName = getOriginalName(customName)
        if originalName then
            spawnItem(originalName)
            task.wait(0.35)
        end
    end
end

-- Check for saved items on script start
if isfile(SaveFileName) then
    local success, data = pcall(function()
        return HttpService:JSONDecode(readfile(SaveFileName))
    end)
    if success and type(data) == "table" and #data > 0 then
        autoLoadEnabled = true
        task.spawn(loadSavedItems)
    end
end

-- Autoload off command
LocalPlayer.Chatted:Connect(function(msg)
    if msg:lower() == ",autoload off" then
        autoLoadEnabled = false
        savedItems = {}
        if isfile(SaveFileName) then
            delfile(SaveFileName)
        end
        WindUI:Notify({
            Title = "Auto Load",
            Content = "Disabled and saved items cleared.",
            Duration = 4
        })
    end
end)

